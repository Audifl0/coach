generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  username       String          @unique
  passwordHash   String
  sessions       Session[]
  athleteProfile AthleteProfile?
  programPlans   ProgramPlan[]
  plannedSessions PlannedSession[]
  plannedExercises PlannedExercise[]
  loggedSets     LoggedSet[]
  adaptiveRecommendations AdaptiveRecommendation[]
  adaptiveRecommendationDecisions AdaptiveRecommendationDecision[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Session {
  id               String    @id @default(cuid())
  sessionTokenHash String    @unique
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?

  @@index([userId])
}

model AthleteProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal               String
  weeklySessionTarget Int
  sessionDuration    String
  equipmentCategories Json
  limitationsDeclared Boolean @default(false)
  limitations        Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ProgramPlan {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String
  startDate   DateTime
  endDate     DateTime
  sessions    PlannedSession[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId, status])
}

model PlannedSession {
  id            String            @id @default(cuid())
  programPlanId String
  programPlan   ProgramPlan       @relation(fields: [programPlanId], references: [id], onDelete: Cascade)
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledDate DateTime
  dayIndex      Int
  focusLabel    String
  state         String
  startedAt     DateTime?
  completedAt   DateTime?
  effectiveDurationSec Int?
  durationCorrectedAt DateTime?
  note          String?
  postSessionFatigue Int?
  postSessionReadiness Int?
  postSessionComment String?
  exercises     PlannedExercise[]
  loggedSets    LoggedSet[]
  adaptiveRecommendations AdaptiveRecommendation[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, scheduledDate])
  @@index([programPlanId, dayIndex])
}

model PlannedExercise {
  id                 String         @id @default(cuid())
  plannedSessionId   String
  plannedSession     PlannedSession @relation(fields: [plannedSessionId], references: [id], onDelete: Cascade)
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderIndex         Int
  exerciseKey        String
  displayName        String
  movementPattern    String
  sets               Int
  targetReps         Int
  targetLoad         String
  restMinSec         Int
  restMaxSec         Int
  isSubstituted      Boolean        @default(false)
  originalExerciseKey String?
  isSkipped          Boolean        @default(false)
  skipReasonCode     String?
  skipReasonText     String?
  skippedAt          DateTime?
  loggedSets         LoggedSet[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([plannedSessionId, orderIndex])
  @@index([userId, plannedSessionId])
}

model LoggedSet {
  id                String          @id @default(cuid())
  plannedSessionId  String
  plannedSession    PlannedSession  @relation(fields: [plannedSessionId], references: [id], onDelete: Cascade)
  plannedExerciseId String
  plannedExercise   PlannedExercise @relation(fields: [plannedExerciseId], references: [id], onDelete: Cascade)
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  setIndex          Int
  weight            Decimal
  reps              Int
  rpe               Decimal?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([plannedExerciseId, setIndex])
  @@index([userId, plannedSessionId])
}

enum AdaptiveRecommendationActionType {
  progress
  hold
  deload
  substitution
}

enum AdaptiveRecommendationStatus {
  proposed
  validated
  pending_confirmation
  applied
  rejected
  fallback_applied
}

enum AdaptiveRecommendationDecisionType {
  policy
  user
  execution
  fallback
}

model AdaptiveRecommendation {
  id                     String                           @id @default(cuid())
  userId                 String
  user                   User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedSessionId       String
  plannedSession         PlannedSession                   @relation(fields: [plannedSessionId], references: [id], onDelete: Cascade)
  actionType             AdaptiveRecommendationActionType
  status                 AdaptiveRecommendationStatus     @default(proposed)
  confidence             Decimal                          @db.Decimal(4, 3)
  confidenceLabel        String
  confidenceReason       String
  warningFlag            Boolean                          @default(false)
  warningText            String?
  fallbackApplied        Boolean                          @default(false)
  fallbackReason         String?
  progressionDeltaLoadPct Decimal?                        @db.Decimal(5, 2)
  progressionDeltaReps   Int?
  progressionDeltaSets   Int?
  substitutionExerciseKey String?
  substitutionDisplayName String?
  substitutionReason      String?
  reasons               Json
  evidenceTags          Json
  forecastPayload       Json
  expiresAt             DateTime?
  appliedAt             DateTime?
  rejectedAt            DateTime?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  decisions             AdaptiveRecommendationDecision[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([plannedSessionId, status])
  @@index([userId, status, createdAt(sort: Desc)])
}

model AdaptiveRecommendationDecision {
  id                  String                           @id @default(cuid())
  recommendationId    String
  recommendation      AdaptiveRecommendation           @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  userId              String
  user                User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  decisionType        AdaptiveRecommendationDecisionType
  previousStatus      AdaptiveRecommendationStatus?
  nextStatus          AdaptiveRecommendationStatus
  decisionReason      String
  evidenceTags        Json
  metadata            Json?
  createdAt           DateTime                         @default(now())

  @@index([recommendationId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

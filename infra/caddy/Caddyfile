{$APP_DOMAIN} {
	encode zstd gzip

	@http method GET HEAD
	handle @http {
		reverse_proxy app:3000 {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Real-IP {remote_host}
		}
	}

	handle {
		reverse_proxy app:3000 {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Real-IP {remote_host}
		}
	}

	log {
		output stdout
		format console
	}
}
